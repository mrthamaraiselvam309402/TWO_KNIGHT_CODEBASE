{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/scripts.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/js/(.*).js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(img|icons|fonts)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=43200" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/:path*" },
    { "source": "/api/zoho-payment-init", "destination": "/api/zoho-payment-init" },
    { "source": "/api/zoho-payment-init/:match*", "destination": "/api/zoho-payment-init" },
    { "source": "/api/zoho-webhook", "destination": "/api/zoho-webhook" },
    { "source": "/api/zoho-webhook/:match*", "destination": "/api/zoho-webhook" }
  ]
}