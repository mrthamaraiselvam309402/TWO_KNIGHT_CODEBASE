# Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Add .env to .gitignore before committing!

# Supabase Configuration (Cloud Database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret for authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=your_strong_random_secret

# Port for local development
PORT=5000

# Stripe Configuration (recommended over Razorpay for US businesses)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Admin Credentials
MASTER_USERNAME=your_unique_master_username
MASTER_PASSWORD=your_strong_master_password
ADMIN_USERNAME=your_unique_admin_username
ADMIN_PASSWORD=your_strong_admin_password