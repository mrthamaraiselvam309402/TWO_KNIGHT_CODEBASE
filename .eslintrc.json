{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-constant-condition": "warn"
  },
  "globals": {
    "allStudents": "writable",
    "allPayments": "writable",
    "allCoaches": "writable",
    "allReceipts": "writable",
    "currentStudent": "writable",
    "window": "writable",
    "document": "readonly",
    "$": "readonly",
    "getStudentMonthlyFee": "readonly",
    "getStudentName": "readonly",
    "getStudentRating": "readonly",
    "getStudentLevel": "readonly",
    "getStudentDate": "readonly",
    "getStudentStatus": "readonly",
    "toast": "readonly",
    "openModal": "readonly",
    "closeModals": "readonly",
    "jsAttrEncode": "readonly",
    "escapeHtml": "readonly",
    "loadAllData": "readonly",
    "Chart": "readonly",
    "renderChildBilling": "readonly",
    "apiCall": "readonly",
    "API_BASE": "readonly",
    "getStudentDueConfig": "readonly",
    "downloadReceipt": "readonly",
    "downloadFinancialStatement": "readonly",
    "shouldShowNotification": "readonly",
    "logAudit": "readonly",
    "initRealtimeNotifications": "readonly",
    "userRole": "readonly",
    "fetchLocal": "readonly",
    "openEventManagement": "readonly",
    "checkCustomCategory": "readonly",
    "setExpMonth": "readonly",
    "setExpPage": "readonly",
    "sendChat": "readonly",
    "sendLoginChat": "readonly",
    "toggleChat": "readonly",
    "toggleLoginChat": "readonly"
  }
}
