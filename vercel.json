{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/scripts.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/js/(.*).js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(img|icons|fonts)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=43200" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/lichess", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/lichess-sync" },
    { "source": "/api/lichess/:match*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/lichess-sync/:match*" },
    { "source": "/api/lichess-proxy/:match*", "destination": "/api/lichess-proxy?type=profile" },
    { "source": "/api/lichess-extras-proxy", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/lichess-sync?extras=1" },
    { "source": "/api/lichess-extras-proxy/:match*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/lichess-sync?extras=1" },
    { "source": "/api/lichess-games-proxy", "destination": "/api/lichess-proxy?type=games" },
    { "source": "/api/lichess-games-proxy/:match*", "destination": "/api/lichess-proxy?type=games" },
    { "source": "/api/test-lichess", "destination": "/api/lichess-proxy?type=test" },
    { "source": "/api/chesscom-proxy", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=profile" },
    { "source": "/api/chesscom-proxy/:match*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=profile" },
    { "source": "/api/chesscom-clubs-proxy", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=clubs" },
    { "source": "/api/chesscom-clubs-proxy/:match*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=clubs" },
    { "source": "/api/chesscom-games-proxy", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=games" },
    { "source": "/api/chesscom-games-proxy/:match*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/chesscom?type=games" },
    { "source": "/api/zoho-payment-init", "destination": "/api/zoho?action=init" },
    { "source": "/api/zoho-payment-init/:match*", "destination": "/api/zoho?action=init" },
    { "source": "/api/zoho-payment-status", "destination": "/api/zoho?action=status" },
    { "source": "/api/zoho-payment-status/:match*", "destination": "/api/zoho?action=status" },
    { "source": "/api/zoho-webhook", "destination": "/api/zoho?action=webhook" },
    { "source": "/api/zoho-webhook/:match*", "destination": "/api/zoho?action=webhook" },
    { "source": "/api/zoho-debug", "destination": "/api/zoho?action=debug" },
    { "source": "/api/:path*", "destination": "https://zznbanjdkwofsvpzybtr.supabase.co/functions/v1/:path*" }
  ]
}